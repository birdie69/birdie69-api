<Project>
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12.0</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- AutoMapper 13.0.1 GHSA-rvv3-g6hj-g44x — suppressed until upgraded -->
    <NuGetAuditSuppress>https://github.com/advisories/GHSA-rvv3-g6hj-g44x</NuGetAuditSuppress>
    <!-- NU1801/NU1301: signature info unavailable (sandbox/offline builds); NU1900: vulnerability data unavailable -->
    <NuGetAudit>false</NuGetAudit>
    <NoWarn>$(NoWarn);NU1903;NU1900;NU1301;NU1801</NoWarn>
    <AnalysisLevel>latest</AnalysisLevel>
    <Authors>birdie69</Authors>
    <Company>birdie69</Company>
    <RootNamespace>$(MSBuildProjectName.Replace("-", "_"))</RootNamespace>
  </PropertyGroup>
</Project>
