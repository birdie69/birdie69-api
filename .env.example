# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by EF Core)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=birdie69;Username=birdie69;Password=REPLACE_ME

# ─── Azure AD B2C ────────────────────────────────────────────────────────────
# From Azure Portal → Azure AD B2C → App registrations
AzureAdB2C__Instance=https://login.microsoftonline.com/tfp/
AzureAdB2C__TenantId=REPLACE_WITH_TENANT_ID
AzureAdB2C__ClientId=REPLACE_WITH_CLIENT_ID
AzureAdB2C__Domain=REPLACE.onmicrosoft.com
AzureAdB2C__SignUpSignInPolicyId=B2C_1_signupsignin

# ─── Redis ────────────────────────────────────────────────────────────────────
# Required by StackExchange.Redis (future: caching, sessions)
Redis__ConnectionString=localhost:6379

# ─── Azure Key Vault (Production) ────────────────────────────────────────────
# Used in production to retrieve secrets via Managed Identity
# Leave empty for local development
AzureKeyVault__Url=

# ─── SendGrid (Email) ────────────────────────────────────────────────────────
# For transactional emails (notifications, etc.)
SendGrid__ApiKey=SG.REPLACE_ME

# ─── Firebase Cloud Messaging (Push Notifications) ───────────────────────────
# From Firebase Console → Project Settings → Service Accounts
Firebase__ProjectId=REPLACE_ME
Firebase__CredentialsPath=firebase-credentials.json

# ─── Logging ─────────────────────────────────────────────────────────────────
# Serilog sink to Azure Monitor (Application Insights)
# Leave empty for local development (console logging only)
ApplicationInsights__ConnectionString=
